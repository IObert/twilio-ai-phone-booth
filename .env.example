# Twilio core
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # required for webhook signature validation only
TWILIO_PHONE_NUMBER=+1234567890

# Twilio API Key (used for all SDK calls)
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Sync service (create in Console > Develop > Sync > Services)
TWILIO_SYNC_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Conversation Intelligence (create config in Console > Voice > Conversation Intelligence)
TWILIO_CONVERSATION_CONFIGURATION_ID=conv_configuration_xxxxxxxxxx
TWILIO_TAC_CI_CONFIGURATION_ID=intelligence_configuration_xxxxxxxxxx

# Call routing
# For testing: a regular E.164 phone number (+14155551234)
# For production at events: a SIP URI (sip:booth@your-pbx.example.com)
SIP_PHONE_ADDRESS=+1234567890

# Optional: order fulfillment backend
MIXOLOGIST_BASE_URL=https://your-mixologist.example.com
MIXOLOGIST_AUTH=user:password

# Public base URL for Twilio webhooks
# Local dev: your ngrok HTTPS URL (e.g. https://abc123.ngrok.io)
# Production: your deployed service URL (e.g. https://tac-voice.example.com)
NGROK_BASE_URL=https://your-tunnel.ngrok.io

# Stats dashboard basic auth
STATS_USER=admin
STATS_PASS=changeme

# OpenAI
OPENAI_API_KEY=sk-...

# Twilio Knowledge Base (optional — TAC knowledge base ID for Guinndex pint price lookups)
# TWILIO_TAC_KNOWLEDGE_BASE_ID=know_knowledgebase_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Attract mode — idle popup that invites passers-by to pick up the phone
# ATTRACT_MODE=true        # enable random 5-10 min idle popups
# ATTRACT_DEV=true         # dev shortcut: fire once after 20 s (overrides ATTRACT_MODE timing)
