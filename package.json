{
	"name": "tac-voice",
	"version": "1.0.0",
	"description": "Voice agent server with Twilio, OpenAI, and Twilio Agent Connect",
	"main": "app/server.ts",
	"type": "module",
	"scripts": {
		"start": "ts-node app/server.ts",
		"dev": "ts-node --esm app/server.ts",
		"backup": "ts-node scripts/backup-sync.ts",
		"cleanup": "ts-node scripts/cleanup-orders.ts",
		"test": "node --import ts-node/esm --test tests/test-*.ts"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/ws": "^8.18.1",
		"ts-node": "^10.9.0",
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"@fastify/static": "^9.1.3",
		"dotenv": "^17.4.2",
		"fastify": "^5.8.5",
		"openai": "^6.38.0",
		"twilio": "^6.0.2",
		"twilio-agent-connect": "^1.0.2",
		"ws": "^8.20.1"
	}
}
